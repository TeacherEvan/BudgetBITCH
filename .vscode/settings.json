{
  "deno.enable": false,
  "svelte.enable-ts-plugin": false,
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.tsserver.maxTsServerMemory": 4096,
  "cSpell.words": [
    "BudgetBITCH",
    "budgetbitch"
  ],
  "files.watcherExclude": {
    "**/budgetbitch/**": true,
    "**/WelcomeWindow-startup/**": true
  },
  "search.exclude": {
    "**/budgetbitch/**": true,
    "**/WelcomeWindow-startup/**": true
  }
}
