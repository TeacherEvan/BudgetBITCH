# Budget-BOSS environment variables (frontend / build-time)
# Copy to .env.local and fill in. Never commit real secrets.

# Convex deployment URL (auto-set by `npx convex dev` / deploy)
NEXT_PUBLIC_CONVEX_URL=

# VAPID public key for Web Push (browser subscription). Generate with:
#   npx tsx scripts/rotate-vapid.ts
# The matching private key goes in the Convex dashboard as VAPID_PRIVATE_KEY.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
