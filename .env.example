# Auth.js session signing secret. Generate with: npx auth secret
AUTH_SECRET=replace_with_a_long_random_secret
# Google OAuth web client credentials for Auth.js login.
AUTH_GOOGLE_ID=replace_with_google_oauth_client_id
AUTH_GOOGLE_SECRET=replace_with_google_oauth_client_secret
# Optional aliases also accepted by the app if your local setup already uses them:
# GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# Clerk Frontend API URL / issuer domain used by Convex auth validation.
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev
# Optional Clerk satellite or proxy settings.
# NEXT_PUBLIC_CLERK_IS_SATELLITE=false
# NEXT_PUBLIC_CLERK_DOMAIN=your-custom-clerk-domain.example.com
# NEXT_PUBLIC_CLERK_PROXY_URL=https://your-proxy.example.com
# Convex deployment slug for CLI/codegen commands.
CONVEX_DEPLOYMENT=your-convex-deployment
# Convex client URL for live views and subscriptions.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# Shared secret used by the app server to project durable Neon changes into Convex.
CONVEX_SYNC_SECRET=replace_with_a_long_random_secret
# Secret used by Vercel Cron Jobs to authorize scheduled replay calls.
CRON_SECRET=replace_with_a_long_random_secret
# Neon pooled connection for the app/runtime.
DATABASE_URL=postgresql://neon_user:neon_password@your-endpoint-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# Neon direct connection for Prisma CLI commands such as migrate and db push.
DIRECT_URL=postgresql://neon_user:neon_password@your-endpoint.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# Optional dedicated shadow database connection for prisma migrate dev.
# SHADOW_DATABASE_URL=postgresql://neon_user:neon_password@your-endpoint.ap-southeast-1.aws.neon.tech/neondb_shadow?sslmode=require
# Required only when testing the encrypted provider connect/revoke routes under /settings/integrations.
PROVIDER_SECRET_ENCRYPTION_KEY=replace_with_a_long_random_secret
# Scaffolded for future email and webhook delivery flows; keep placeholders until those routes are active.
RESEND_API_KEY=re_replace_me
INNGEST_EVENT_KEY=evt_replace_me
INNGEST_SIGNING_KEY=signkey_replace_me
WEBHOOK_SIGNING_SECRET=whsec_replace_me
SENTRY_DSN=https://replace-me.ingest.sentry.io/project
NEXT_PUBLIC_APP_URL=http://localhost:3000
