# --- Convex (required) ---
# CLI/deploy target. Use dev:<slug> for local, prod:steady-ox-280 for production.
CONVEX_DEPLOYMENT=dev:your-convex-deployment
# Public Convex cloud URL baked into the browser bundle (auth + live data).
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
# Public Convex site URL (client-side redirect target / issuer reference).
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-convex-deployment.convex.site

# CONVEX_SITE_URL is a BUILT-IN Convex variable (always https://<slug>.convex.site).
# It is read by convex/auth.config.ts. Do NOT run `npx convex env set CONVEX_SITE_URL`
# — Convex rejects it with EnvVarNameForbidden because it is auto-derived. Listed here
# only as a reference for local tooling; the live value is managed by Convex.
CONVEX_SITE_URL=https://your-convex-deployment.convex.site

# App origin accepted by Convex Auth redirects (local: http://localhost:3000).
SITE_URL=http://localhost:3000

# Shared secret for trusted server-side Convex sync (auth bootstrap + projection replay).
# Must match between the Vercel build env and the Convex deployment env.
CONVEX_SYNC_SECRET=replace_with_a_long_random_secret

# --- Secrets (NEVER commit; put in .env, not .env.example) ---
# Convex deploy key for CI/prod deploys. Keep in .env only.
# CONVEX_DEPLOY_KEY=prod:<key>
