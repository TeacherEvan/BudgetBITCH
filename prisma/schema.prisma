generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceType {
  personal
  household
  business
}

enum WorkspaceRole {
  owner
  editor
  approver
  read_only
}

enum AuditAction {
  workspace_created
  workspace_member_added
  budget_category_created
  expense_recorded
  bill_created
  home_location_saved
  reminder_created
  notification_sent
  api_token_created
  webhook_delivered
  integration_connected
  integration_revoked
  consent_recorded
  personalization_updated
}

enum TransactionType {
  expense
  income
  adjustment
}

enum TransactionSource {
  manual
}

enum GenderIdentity {
  woman
  man
  nonbinary
  self_describe
  prefer_not_to_say
}

enum PronounPreference {
  she_her
  he_him
  they_them
  name_only
  self_describe
  prefer_not_to_say
}

enum StartSmartStatus {
  draft
  generated
  accepted
}

enum ConfidenceLabel {
  verified
  estimated
  user_entered
}

enum DailyCheckInStatus {
  completed
  skipped
}

enum DailyCheckInAlertStatus {
  open
  resolved
  dismissed
}

enum DailyCheckInAlertSeverity {
  info
  warning
  critical
}

enum ProjectionTopic {
  daily_check_in
  daily_check_in_alert
}

enum ProjectionOutboxStatus {
  pending
  processing
  failed
  succeeded
}

model UserProfile {
  id                   String                    @id @default(cuid())
  clerkUserId          String                    @unique
  email                String                    @unique
  displayName          String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  memberships          WorkspaceMember[]
  auditEvents          AuditEvent[]
  dailyCheckIns        DailyCheckIn[]
  financialTransactions FinancialTransaction[]
  jobPreferences       UserJobPreference[]
  personalizationProfile UserPersonalizationProfile?
  workspacePreferences WorkspaceUserPreference[]
}

model Workspace {
  id                 String                    @id @default(cuid())
  name               String
  type               WorkspaceType
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  members            WorkspaceMember[]
  accounts           Account[]
  categories         BudgetCategory[]
  bills              Bill[]
  financialTransactions FinancialTransaction[]
  homeLocations      WorkspaceHomeLocation[]
  reminderRules      ReminderRule[]
  notifications      NotificationPreference[]
  auditEvents        AuditEvent[]
  apiTokens          ApiToken[]
  integrations       IntegrationConnection[]
  consents           ConsentReceipt[]
  checkIns           DailyCheckIn[]
  checkInAlerts      DailyCheckInAlert[]
  projectionOutbox   ProjectionOutbox[]
  userPreferences    WorkspaceUserPreference[]
  startSmartProfiles StartSmartProfile[]
  regionalSnapshots  RegionalSnapshot[]
  moneyBlueprints    MoneyBlueprintSnapshot[]
}

model DailyCheckIn {
  id          String             @id @default(cuid())
  workspaceId String
  actorUserId String?
  checkInDate DateTime           @db.Date
  status      DailyCheckInStatus @default(completed)
  checkInJson Json
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     UserProfile?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  alerts    DailyCheckInAlert[]

  @@unique([workspaceId, checkInDate])
  @@index([actorUserId, checkInDate])
}

model DailyCheckInAlert {
  id           String                    @id @default(cuid())
  workspaceId  String
  checkInId    String
  status       DailyCheckInAlertStatus   @default(open)
  severity     DailyCheckInAlertSeverity @default(info)
  code         String
  title        String
  message      String
  metadataJson Json?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  resolvedAt   DateTime?

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  checkIn   DailyCheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)

  @@unique([checkInId, code])
  @@index([checkInId, status])
  @@index([workspaceId, status, severity])
}

model ProjectionOutbox {
  id            String                 @id @default(cuid())
  workspaceId   String
  topic         ProjectionTopic
  sourceId      String
  dedupeKey     String                 @unique
  payloadJson   Json
  status        ProjectionOutboxStatus @default(pending)
  attemptCount  Int                    @default(0)
  availableAt   DateTime               @default(now())
  lastAttemptAt DateTime?
  processedAt   DateTime?
  lastError     String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([workspaceId, status, availableAt])
  @@index([topic, sourceId])
}

model WorkspaceUserPreference {
  id           String    @id @default(cuid())
  workspaceId  String
  userId       String
  isDefault    Boolean   @default(false)
  lastOpenedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, isDefault, lastOpenedAt])
}

model StartSmartProfile {
  id                String                  @id @default(cuid())
  workspaceId       String
  templateId        String?
  regionKey         String
  householdKind     String
  status            StartSmartStatus        @default(draft)
  profileJson       Json
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  regionalSnapshots RegionalSnapshot[]
  blueprintSnapshots MoneyBlueprintSnapshot[]

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([regionKey])
}

model RegionalSnapshot {
  id             String           @id @default(cuid())
  workspaceId    String
  profileId      String
  regionKey      String
  confidence     ConfidenceLabel @default(estimated)
  assumptionsJson Json
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  profile   StartSmartProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([workspaceId, regionKey])
}

model MoneyBlueprintSnapshot {
  id            String                  @id @default(cuid())
  workspaceId   String
  profileId     String
  regionKey     String
  householdKind String
  status        StartSmartStatus        @default(generated)
  blueprintJson Json
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  profile   StartSmartProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([regionKey])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Account {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  balance     Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  financialTransactions FinancialTransaction[]
}

model BudgetCategory {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  monthlyLimit Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  financialTransactions FinancialTransaction[]
}

model FinancialTransaction {
  id               String            @id @default(cuid())
  workspaceId      String
  actorUserId      String?
  accountId        String?
  budgetCategoryId String?
  type             TransactionType   @default(expense)
  source           TransactionSource @default(manual)
  merchantName     String?
  amount           Decimal           @db.Decimal(12, 2)
  occurredAt       DateTime
  note             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor          UserProfile?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  account        Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  budgetCategory BudgetCategory? @relation(fields: [budgetCategoryId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
  @@index([workspaceId, budgetCategoryId, occurredAt])
}

model WorkspaceHomeLocation {
  id          String   @id @default(cuid())
  workspaceId String
  city        String
  stateCode   String
  countryCode String
  source      String   @default("user_selected")
  consentedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, city, stateCode, countryCode])
  @@index([countryCode, stateCode, city])
}

model UserPersonalizationProfile {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  genderIdentity         GenderIdentity?
  genderSelfDescription  String?
  pronouns               PronounPreference?
  pronounSelfDescription String?
  communicationStyle     String?
  coachingIntensity      String?
  consentedAt            DateTime?
  privacyVersion         String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserJobPreference {
  id                 String   @id @default(cuid())
  userId             String
  roleInterests      String[]
  certifications     String[]
  licenseTypes       String[]
  careWorkInterest   Boolean  @default(false)
  childCareInterest  Boolean  @default(false)
  petCareInterest    Boolean  @default(false)
  nursingInterest    Boolean  @default(false)
  teachingInterest   Boolean  @default(false)
  notificationEnabled Boolean @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, notificationEnabled])
}

model Bill {
  id             String   @id @default(cuid())
  workspaceId    String
  title          String
  amount         Decimal  @db.Decimal(12, 2)
  dueDate        DateTime
  recurrenceRule String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ReminderRule {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  triggerType String
  actionType  String
  offsetDays  Int?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id          String   @id @default(cuid())
  workspaceId String
  inApp       Boolean  @default(true)
  email       Boolean  @default(true)
  push        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ApiToken {
  id          String   @id @default(cuid())
  workspaceId String
  label       String
  tokenHash   String
  scopes      String[]
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model IntegrationConnection {
  id                String   @id @default(cuid())
  workspaceId       String
  provider          String
  displayName       String
  authType          String
  encryptedSecret   String?
  secretFingerprint String?
  status            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  revokedAt         DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ConsentReceipt {
  id                String   @id @default(cuid())
  workspaceId       String
  provider          String
  disclosureVersion String
  disclosuresJson   Json
  acceptedAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id           String      @id @default(cuid())
  workspaceId  String
  actorUserId  String
  action       AuditAction
  targetType   String
  targetId     String
  metadataJson Json
  createdAt    DateTime    @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     UserProfile @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
}
